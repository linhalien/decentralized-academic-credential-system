# CredChain Frontend — Sepolia (default)
# Copy: cp .env.example .env

# Network: sepolia | localhost
VITE_NETWORK=sepolia

# Contract addresses after deploy (npm run deploy:sepolia)
VITE_REGISTRY_ADDRESS=0x8AF83A4F2d5B4584d6cb9C85b5D018326eb94cf3
VITE_VERIFIER_ADDRESS=0x0F79D6c7B3BC1138fb47318c77FfD777057d3241

# Optional — only if you need to load old universities from chain events in a new browser
# VITE_REGISTRY_DEPLOY_BLOCK=10968743

# Optional — custom Sepolia RPC (defaults to publicnode if omitted)
# VITE_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
