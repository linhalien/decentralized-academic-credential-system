VITE_REGISTRY_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
VITE_VERIFIER_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Network (localhost | sepolia)
VITE_NETWORK=localhost
