# CredChain Scripts — Sepolia (default)
# Copy: cp .env.example .env

# Issuer wallet for CLI sign/anchor (optional if using frontend MetaMask only)
UNIVERSITY_PRIVATE_KEY=0x_your_issuer_private_key_here

# Deployed addresses (same as frontend/.env)
REGISTRY_ADDRESS=0x8AF83A4F2d5B4584d6cb9C85b5D018326eb94cf3
VERIFIER_ADDRESS=0x0F79D6c7B3BC1138fb47318c77FfD777057d3241

# Sepolia RPC
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
NETWORK=sepolia

# For local Hardhat only:
# RPC_URL=http://127.0.0.1:8545
# NETWORK=localhost
